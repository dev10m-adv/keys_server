NODE_ENV=production
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=secmail
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONN_TIMEOUT_MS=10000

# ── SMTP (leave blank in dev — OTPs are printed to console instead) ───────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@secmail.app

# ── Secrets ───────────────────────────────────────────────────────────────────
# 256-bit hex secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FETCH_TOKEN_SECRET=

# ── App ───────────────────────────────────────────────────────────────────────
SERVER_BASE_URL=https://your-server.com

# Comma-separated list of allowed origins (use * only in dev)
CORS_ORIGINS=https://your-app.com

# Structured log level: fatal | error | warn | info | debug (default: info)
LOG_LEVEL=info

# Max JSON body size per request (default: 1mb)
JSON_LIMIT=1mb
